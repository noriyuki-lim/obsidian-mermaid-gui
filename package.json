{
  "name": "mermaid-gui-editor",
  "version": "0.2.2",
  "description": "Edit Mermaid diagrams — flowchart, sequence, class, state, gantt, kanban, and more — inside Obsidian notes with a GUI editor that saves back as plain Mermaid text.",
  "main": "main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit && node esbuild.config.mjs",
    "build:js": "node esbuild.config.mjs",
    "typecheck": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
